{
  "id": "tpl-american-amber",
  "name": "American Amber Ale",
  "description": "The original American craft beer style. Caramel malt backbone meets citrus-pine American hops. Balanced, approachable, and endlessly satisfying. A perfect second brew after your first pale ale.",
  "style_id": "19A",
  "difficulty": "beginner",
  "estimated_brew_to_ready_days": 21,
  "base_batch_size_l": 20,
  "fermentables": [
    { "fermentable_id": "pale-2-row-us", "amount_kg": 3.5, "use": "mash" },
    { "fermentable_id": "crystal-60-crisp", "amount_kg": 0.4, "use": "mash" },
    { "fermentable_id": "munich-light-weyermann", "amount_kg": 0.3, "use": "mash" }
  ],
  "hops": [
    { "hop_id": "cascade", "amount_g": 25, "use": "boil", "time_min": 60, "form": "pellet" },
    { "hop_id": "cascade", "amount_g": 20, "use": "boil", "time_min": 15, "form": "pellet" },
    { "hop_id": "centennial", "amount_g": 25, "use": "boil", "time_min": 5, "form": "pellet" }
  ],
  "cultures": [
    { "culture_id": "us-05", "amount_g_or_ml": 11.5 }
  ],
  "process": {
    "water_profile": {
      "name": "Pale Ale (balanced)",
      "calcium_ppm": 60, "magnesium_ppm": 8, "sodium_ppm": 15,
      "sulfate_ppm": 80, "chloride_ppm": 60, "bicarbonate_ppm": 40
    },
    "mash": {
      "steps": [
        { "name": "Sacc rest", "temperature_c": 66, "duration_min": 60, "type": "infusion", "rest_purpose": "alpha-amylase" },
        { "name": "Mash out", "temperature_c": 76, "duration_min": 10, "type": "temperature", "rest_purpose": "mash-out" }
      ],
      "water_grain_ratio_l_per_kg": 3.0,
      "sparge": "batch",
      "target_ph": 5.4
    },
    "boil": {
      "duration_min": 60,
      "vigour": "rolling"
    },
    "fermentation": {
      "pitch_temp_c": 18,
      "pitch_rate_million_cells_per_ml_per_plato": 0.75,
      "oxygenation": "shake",
      "steps": [
        {
          "name": "Primary",
          "type": "primary",
          "start_condition": { "type": "time-after-pitch", "value": 0 },
          "temperature_c": 19,
          "end_condition": { "type": "duration-days", "value": 10 }
        },
        {
          "name": "Conditioning",
          "type": "secondary",
          "start_condition": { "type": "previous-step-end", "value": 0 },
          "temperature_c": 19,
          "end_condition": { "type": "duration-days", "value": 4 }
        },
        {
          "name": "Cold crash",
          "type": "crash",
          "start_condition": { "type": "previous-step-end", "value": 0 },
          "temperature_c": 2,
          "ramp_rate_c_per_day": -3,
          "end_condition": { "type": "duration-days", "value": 3 }
        }
      ]
    },
    "packaging": {
      "method": "bottle",
      "carbonation_volumes_co2": 2.4,
      "bottle_priming": {
        "sugar_type": "corn-sugar",
        "sugar_g_per_l": 5.0,
        "conditioning_temp_c": 20,
        "conditioning_days": 14
      },
      "serving_temp_c": 10
    }
  },
  "expected_profile": {
    "overall_summary": "Caramel and toffee malt balanced by citrus-pine American hops. Medium body, moderate bitterness, and a clean finish. The definition of balance in American craft beer.",
    "dominant_descriptors": ["caramel", "citrus", "pine", "toffee", "balanced"],
    "body": "medium",
    "bitterness_perception": "medium",
    "sweetness": "balanced",
    "finish": "Clean with lingering hop bitterness and caramel malt sweetness"
  },
  "tips": [
    "Don't overdo the crystal malt. More than 10% and it becomes cloying.",
    "Cascade and Centennial are classic, but feel free to sub in Citra or Amarillo for a modern twist.",
    "Amber ale is about balance. If the hops or malt dominate, adjust your recipe.",
    "A short cold crash dramatically improves clarity."
  ],
  "common_mistakes": [
    "Too much crystal malt (ends up syrupy and sweet)",
    "Under-hopping (becomes a bland caramel beer)",
    "Fermenting too warm (produces fruity esters that clash with the caramel)",
    "Bottling too early (needs time for the crystal malt character to mellow)"
  ]
}
