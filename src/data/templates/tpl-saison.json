{
  "id": "tpl-saison",
  "name": "Farmhouse Saison",
  "description": "Dry, spicy, and endlessly drinkable. The saison yeast is the star — let it run warm and it rewards you with pepper, citrus, and a bone-dry finish. A forgiving style that tolerates imperfect temperature control.",
  "style_id": "25B",
  "difficulty": "intermediate",
  "estimated_brew_to_ready_days": 21,
  "base_batch_size_l": 20,
  "fermentables": [
    { "fermentable_id": "pilsner-weyermann", "amount_kg": 3.5, "use": "mash" },
    { "fermentable_id": "wheat-malt-pale", "amount_kg": 0.8, "use": "mash" },
    { "fermentable_id": "caramunich-3", "amount_kg": 0.2, "use": "mash" }
  ],
  "hops": [
    { "hop_id": "saaz", "amount_g": 25, "use": "boil", "time_min": 60, "form": "pellet" },
    { "hop_id": "saaz", "amount_g": 20, "use": "boil", "time_min": 15, "form": "pellet" },
    { "hop_id": "east-kent-goldings", "amount_g": 20, "use": "boil", "time_min": 5, "form": "pellet" }
  ],
  "cultures": [
    { "culture_id": "belle-saison", "amount_g_or_ml": 11.5 }
  ],
  "process": {
    "water_profile": {
      "name": "Pale Ale (balanced)",
      "calcium_ppm": 60, "magnesium_ppm": 8, "sodium_ppm": 15,
      "sulfate_ppm": 80, "chloride_ppm": 60, "bicarbonate_ppm": 40
    },
    "mash": {
      "steps": [
        { "name": "Sacc rest", "temperature_c": 64, "duration_min": 60, "type": "infusion", "rest_purpose": "beta-amylase" },
        { "name": "Mash out", "temperature_c": 76, "duration_min": 10, "type": "temperature", "rest_purpose": "mash-out" }
      ],
      "water_grain_ratio_l_per_kg": 3.0,
      "sparge": "batch",
      "target_ph": 5.3
    },
    "boil": {
      "duration_min": 60,
      "vigour": "rolling"
    },
    "fermentation": {
      "pitch_temp_c": 20,
      "pitch_rate_million_cells_per_ml_per_plato": 0.75,
      "oxygenation": "shake",
      "steps": [
        {
          "name": "Primary",
          "type": "primary",
          "start_condition": { "type": "time-after-pitch", "value": 0 },
          "temperature_c": 24,
          "end_condition": { "type": "duration-days", "value": 7 }
        },
        {
          "name": "Warm finish",
          "type": "free-rise",
          "start_condition": { "type": "previous-step-end", "value": 0 },
          "temperature_c": 28,
          "end_condition": { "type": "duration-days", "value": 5 }
        },
        {
          "name": "Cold crash",
          "type": "crash",
          "start_condition": { "type": "previous-step-end", "value": 0 },
          "temperature_c": 2,
          "ramp_rate_c_per_day": -3,
          "end_condition": { "type": "duration-days", "value": 3 }
        }
      ]
    },
    "packaging": {
      "method": "bottle",
      "carbonation_volumes_co2": 3.0,
      "bottle_priming": {
        "sugar_type": "corn-sugar",
        "sugar_g_per_l": 6.0,
        "conditioning_temp_c": 22,
        "conditioning_days": 14
      },
      "serving_temp_c": 8
    }
  },
  "expected_profile": {
    "overall_summary": "Dry, spicy, and refreshing. Pepper and citrus from the yeast, a soft grainy body, and a finish so dry it almost snaps. Built for hot days and long evenings.",
    "dominant_descriptors": ["peppery", "citrus", "dry", "spicy", "grainy"],
    "body": "medium-light",
    "bitterness_perception": "medium",
    "sweetness": "dry",
    "finish": "Bone dry with lingering pepper and a faint herbal bitterness"
  },
  "tips": [
    "Let it run warm. 24-28°C is where the magic happens. Don't panic.",
    "Belle Saison will keep attenuating until there's nothing left. Expect a very low FG.",
    "Add cracked black pepper or orange peel in the last 5 minutes of the boil for extra complexity.",
    "High carbonation is essential — 3.0+ vols gives the proper effervescence."
  ],
  "common_mistakes": [
    "Fermenting too cold (kills the saison character)",
    "Bottling before it hits final gravity (can lead to over-carbonation or bottle bombs)",
    "Under-hopping (needs enough bitterness to balance the dryness)",
    "Rushing it (saison improves with 2-3 weeks in the bottle)"
  ]
}
